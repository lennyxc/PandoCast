<Application x:Class="PandoCast.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             xmlns:local="clr-namespace:PandoCast.UI"
             Startup="Application_Startup"
             Exit="Application_Exit">

    <Application.Resources>
        <ContextMenu x:Shared="false" x:Key="SysTrayMenu">
            <MenuItem Header="Settings / Login" Click="Settings_Click" />
            <Separator />
            <MenuItem Header="Exit PandoCast" Click="ExitApplication_Click" />
        </ContextMenu>

        <tb:TaskbarIcon x:Key="PandoCastTrayIcon"
                        IconSource="/PandoCast_Logo.ico"
                        ToolTipText="PandoCast - Starting..."
                        ContextMenu="{StaticResource SysTrayMenu}">

            <tb:TaskbarIcon.TrayPopup>
                <local:PlayerFlyout />
            </tb:TaskbarIcon.TrayPopup>

        </tb:TaskbarIcon>
    </Application.Resources>
</Application>