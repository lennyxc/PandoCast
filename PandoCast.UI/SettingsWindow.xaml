<Window x:Class="PandoCast.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PandoCast Settings" Height="460" Width="410"
        Icon="/PandoCast_Logo.ico"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="20">
        <TextBlock Text="Pandora Account" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Email Address:" />
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="EmailTextBox" Margin="0,0,0,10" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Password:" Margin="0,5,0,0"/>
            <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="PasswordBox" Margin="0,5,0,10" />

            <Button Grid.Row="2" Grid.Column="1" x:Name="SaveButton" Content="Save &amp; Login"
                    Width="100" HorizontalAlignment="Right" Margin="0,15,0,0"
                    Click="SaveButton_Click"/>
        </Grid>

        <Separator Margin="0,24,0,16"/>

        <TextBlock Text="Chromecast Receiver" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
        <TextBlock Text="Choose the soundbar or Chromecast target for playback. Leave Auto selected to use the first discovered receiver."
                   TextWrapping="Wrap" Foreground="#555555" Margin="0,0,0,12"/>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox Grid.Row="0" Grid.Column="0" x:Name="ReceiverComboBox"
                      Height="26" DisplayMemberPath="DisplayName" SelectedValuePath="Name"
                      SelectionChanged="ReceiverComboBox_SelectionChanged"/>
            <Button Grid.Row="0" Grid.Column="1" x:Name="RefreshReceiversButton" Content="Refresh"
                    Width="76" Margin="8,0,0,0" Click="RefreshReceiversButton_Click"/>

            <TextBlock Grid.Row="1" Grid.ColumnSpan="2" x:Name="ReceiverStatusTextBlock"
                       Text="Receiver discovery has not run yet." Foreground="#666666"
                       TextWrapping="Wrap" Margin="0,8,0,0"/>

            <Button Grid.Row="2" Grid.ColumnSpan="2" x:Name="SaveReceiverButton" Content="Apply Receiver"
                    Width="110" HorizontalAlignment="Right" Margin="0,15,0,0"
                    Click="SaveReceiverButton_Click"/>
        </Grid>
    </StackPanel>
    </ScrollViewer>
</Window>
