<UserControl x:Class="PandoCast.UI.PlayerFlyout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="720" Width="760"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <Style x:Key="InvisibleScrollRepeatButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemedScrollThumb" TargetType="Thumb">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" Background="#5C5C5C" CornerRadius="4" Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#747474"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#8FBCEC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="#292929"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Margin="0,2,0,2">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource InvisibleScrollRepeatButton}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ThemedScrollThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource InvisibleScrollRepeatButton}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#1E1E1E" CornerRadius="8" BorderBrush="#333333" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="128"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="HeaderTextBlock" Text="Your Stations" Foreground="White" 
                       FontSize="20" FontWeight="Bold" Margin="15"/>

            <ListBox x:Name="StationListBox" Grid.Row="1" Grid.Column="0" Margin="10,0,6,10" 
                      Background="Transparent" BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.VerticalScrollBarVisibility="Visible"
                      SelectionChanged="StationListBox_SelectionChanged">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Width="45" Height="45">
                                <Border Background="#3A3A3A" CornerRadius="4" />
                                <TextBlock Text="P" Foreground="#777777" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <Image Source="{Binding ArtSource}" Width="45" Height="45" Stretch="UniformToFill" />
                            </Grid>

                            <TextBlock Grid.Column="1" Text="{Binding StationName}" 
                                       Foreground="White" FontSize="14" 
                                       VerticalAlignment="Center" Margin="10,0,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border x:Name="ModePanel" Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Margin="6,10,10,10" Padding="12"
                    Background="#252525" BorderBrush="#3A3A3A" BorderThickness="1"
                    CornerRadius="6" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="ModeHeaderTextBlock" Text="Choose a station mode"
                               Foreground="#E8E8E8" FontSize="12" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>

                    <ListBox x:Name="ModeListBox" Grid.Row="1" Margin="0,8,0,0"
                             Background="Transparent" BorderThickness="0"
                             HorizontalContentAlignment="Stretch"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Visible"
                             SelectionChanged="ModeListBox_SelectionChanged">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,7"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder" Background="#303030"
                                                    BorderBrush="#444444" BorderThickness="1"
                                                    CornerRadius="6" Padding="9">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#363636"/>
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#666666"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#31445A"/>
                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#8FBCEC"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" Foreground="White"
                                               FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding DisplayDescription}" Foreground="#B8B8B8"
                                               FontSize="11" TextWrapping="Wrap"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#2D2D2D" BorderBrush="#3D3D3D" BorderThickness="0,1,0,0" CornerRadius="0,0,8,8" Padding="12,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock x:Name="TrackTitleTextBlock" Text="Select a station to play..."
                                   Foreground="White" FontSize="13" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="TrackSubtitleTextBlock" Text="Pandora will choose the tracks for the station."
                                   Foreground="#B0B0B0" FontSize="11"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="PlaybackStatusTextBlock" Text=""
                                   Foreground="#888888" FontSize="11"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="ReceiverTextBlock" Text=""
                                   Foreground="#8FBCEC" FontSize="11"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <Button x:Name="PlayPauseButton" Grid.Row="0" Grid.Column="1" Content="Play"
                            Width="72" Height="32" VerticalAlignment="Center"
                            IsEnabled="False" Click="PlayPauseButton_Click"/>

                    <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="38"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Volume" Foreground="#B0B0B0" FontSize="11"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider x:Name="VolumeSlider" Grid.Column="1" Minimum="0" Maximum="100" Value="50"
                                IsEnabled="False" VerticalAlignment="Center"
                                ValueChanged="VolumeSlider_ValueChanged"/>
                        <TextBlock x:Name="VolumeTextBlock" Grid.Column="2" Text="50%" Foreground="#B0B0B0"
                                   FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
